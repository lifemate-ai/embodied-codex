# Choose one: home_assistant or nature_remo.
# If left blank, room-actuator-mcp auto-selects nature_remo when
# NATURE_REMO_ACCESS_TOKEN is present, otherwise home_assistant.
ROOM_ACTUATOR_BACKEND=

# Home Assistant backend
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_VERIFY_SSL=true

# Nature Remo cloud backend
NATURE_REMO_ACCESS_TOKEN=
NATURE_REMO_API_BASE_URL=https://api.nature.global
