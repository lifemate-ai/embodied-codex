{
  "mcpServers": {
    "ip-webcam": {
      "command": "uv",
      "args": ["run", "--directory", "ip-webcam-mcp", "ip-webcam-mcp"],
      "env": {
        "IP_WEBCAM_HOST": "192.168.1.xxx",
        "IP_WEBCAM_PORT": "8080"
      }
    },
    "usb-webcam": {
      "command": "uv",
      "args": ["run", "--directory", "usb-webcam-mcp", "usb-webcam-mcp"]
    },
    "wifi-cam": {
      "command": "uv",
      "args": ["run", "--directory", "wifi-cam-mcp", "wifi-cam-mcp"],
      "env": {
        "TAPO_CAMERA_HOST": "192.168.1.xxx",
        "TAPO_MOUNT_MODE": "ceiling",
        "TAPO_USERNAME": "your-username",
        "TAPO_PASSWORD": "your-password"
      }
    },
    "hearing": {
      "command": "uv",
      "args": ["run", "--directory", "hearing", "hearing-mcp"],
      "env": {
        "MCP_BEHAVIOR_TOML": "/path/to/embodied-codex/mcpBehavior.toml"
      }
    },
    "mobility": {
      "command": "uv",
      "args": ["run", "--directory", "mobility-mcp", "mobility-mcp"],
      "env": {
        "TUYA_DEVICE_ID": "your-tuya-device-id",
        "TUYA_API_KEY": "your-tuya-api-key",
        "TUYA_API_SECRET": "your-tuya-api-secret",
        "TUYA_API_REGION": "us"
      }
    },
    "desire-system": {
      "command": "uv",
      "args": ["run", "--directory", "desire-system", "desire-system"]
    },
    "memory": {
      "command": "uv",
      "args": ["run", "--directory", "memory-mcp", "memory-mcp"]
    },
    "system-temperature": {
      "command": "uv",
      "args": ["run", "--directory", "system-temperature-mcp", "system-temperature-mcp"]
    },
    "tts": {
      "command": "uv",
      "args": ["run", "--directory", "tts-mcp", "tts-mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "your-api-key",
        "ELEVENLABS_VOICE_ID": "your-voice-id",
        "ELEVENLABS_MODEL_ID": "eleven_v3",
        "ELEVENLABS_OUTPUT_FORMAT": "mp3_44100_128",
        "VOICEVOX_URL": "http://localhost:50021",
        "VOICEVOX_SPEAKER": "3",
        "TTS_PLAYBACK": "pw-play",
        "GO2RTC_URL": "http://localhost:1984",
        "GO2RTC_STREAM": "tapo_cam"
      }
    },
    "room-actuator": {
      "command": "uv",
      "args": ["run", "--directory", "room-actuator-mcp", "room-actuator-mcp"],
      "env": {
        "ROOM_ACTUATOR_BACKEND": "home_assistant",
        "HOME_ASSISTANT_URL": "http://homeassistant.local:8123",
        "HOME_ASSISTANT_TOKEN": "your-home-assistant-token"
      }
    },
    "morning-call": {
      "command": "uv",
      "args": ["run", "--directory", "morning-call-mcp", "morning-call-mcp"],
      "env": {
        "TWILIO_ACCOUNT_SID": "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "TWILIO_AUTH_TOKEN": "your-twilio-auth-token",
        "TWILIO_FROM_NUMBER": "+18125551234",
        "TWILIO_TO_NUMBER": "+819012345678",
        "ELEVENLABS_API_KEY": "your-api-key",
        "ELEVENLABS_VOICE_ID": "your-voice-id",
        "NGROK_AUTH_TOKEN": "your-ngrok-auth-token"
      }
    },
    "toio": {
      "command": "uv",
      "args": ["run", "--directory", "toio-mcp", "toio-mcp"],
      "env": {
        "TOIO_CUBE_NAME": "your-cube-name",
        "TOIO_SCAN_TIMEOUT": "10",
        "TOIO_SPEED": "80"
      }
    }
  }
}
